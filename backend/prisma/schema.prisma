// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  OWNER
  CLIENT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum BusinessSource {
  MANUAL
  GOOGLE
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  password      String
  role          UserRole
  name          String
  bookings      Booking[]
  roomBookings  RoomBooking[]
  businesses    Business[]
  refreshTokens RefreshToken[]
  notifications Notification[]
  claimRequests ClaimRequest[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Business {
  id             String           @id @default(uuid())
  name           String
  category       String
  description    String
  metadata       Json?
  latitude       Float
  longitude      Float
  municipality   String?
  isActive       Boolean          @default(true)
  ownerId        String?
  owner          User?            @relation(fields: [ownerId], references: [id])
  isClaimed      Boolean          @default(false)
  claimedAt      DateTime?
  source         BusinessSource   @default(MANUAL)
  googlePlaceId  String?          @unique
  bookings       Booking[]
  roomBookings   RoomBooking[]
  roomTypes      RoomType[]
  items          Item[]
  operatingHours OperatingHour[]
  claimRequests  ClaimRequest[]
  suggestions    DataUpdateSuggestion[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Booking {
  id         String        @id @default(uuid())
  startDate  DateTime
  endDate    DateTime
  status     BookingStatus
  userId     String
  businessId String
  user       User          @relation(fields: [userId], references: [id])
  business   Business      @relation(fields: [businessId], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("table_bookings")
}

model RoomBooking {
  id          String        @id @default(uuid())
  startDate   DateTime
  endDate     DateTime
  status      BookingStatus
  userId      String
  businessId  String
  guestName   String?
  guestPhone  String?
  adults      Int           @default(1)
  children    Int           @default(0)
  rooms       Int           @default(1)
  totalPrice  Float?
  notes       String?
  roomTypeId  String?
  roomType    RoomType?     @relation(fields: [roomTypeId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  business    Business      @relation(fields: [businessId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("room_bookings")
}

model RoomType {
  id                String        @id @default(uuid())
  businessId        String
  business          Business      @relation(fields: [businessId], references: [id])
  name              String
  description       String        @default("")
  pricePerNight     Float
  maxGuests         Int           @default(2)
  totalRooms        Int           @default(1)
  available         Boolean       @default(true)
  amenities         String[]      @default([])
  minNights         Int           @default(1)
  taxRate           Float         @default(0)
  weekendMultiplier Float         @default(1.0)
  seasonalRates     Json?         // [{ label, startDate, endDate, multiplier }]
  photos            String[]      @default([])
  bookings          RoomBooking[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("room_types")
}

model RefreshToken {
  id         String   @id @default(uuid())
  tokenId    String   @unique
  tokenHash  String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Item {
  id          String   @id @default(uuid())
  name        String
  price       Float
  capacity    Int
  description String
  available   Boolean  @default(true)
  totalRooms  Int      @default(1)
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OperatingHour {
  id         String   @id @default(uuid())
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, dayOfWeek])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  data      Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClaimRequest {
  id           String      @id @default(uuid())
  businessId   String
  userId       String
  status       ClaimStatus @default(PENDING)
  evidence     String
  adminNote    String?
  reviewedBy   String?
  reviewedAt   DateTime?
  business     Business    @relation(fields: [businessId], references: [id])
  user         User        @relation(fields: [userId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([businessId, userId])
  @@map("claim_requests")
}

model DataUpdateSuggestion {
  id           String           @id @default(uuid())
  businessId   String
  business     Business         @relation(fields: [businessId], references: [id])
  source       BusinessSource   // GOOGLE or OUTSCRAPER (via GOOGLE enum)
  status       SuggestionStatus @default(PENDING)
  suggestedData Json            // campos sugeridos: name, category, address, phone, etc.
  currentData  Json             // snapshot dos dados actuais no momento da sugestão
  reviewedAt   DateTime?
  expiresAt    DateTime?        // auto-expira após 30 dias se não for respondida
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("data_update_suggestions")
}
