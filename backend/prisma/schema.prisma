// =============================================================================
// AcheiAqui — Schema Prisma v2
// SaaS Multi-tenant · Multi-módulo
//
// CONVENÇÃO DE NOMES:
//   Sem prefixo   → infraestrutura core (User, Business, Notification…)
//   ht_           → Hospitality (Hotelaria / PMS)
//   di_           → Dining (Restauração)
//   bw_           → Beauty & Wellness
//   ev_           → Events
//   he_           → Health
//   ed_           → Education
//   ps_           → Professional Services
//
// PILARES DE SEGURANÇA:
//   [TENANT]  businessId obrigatório em todos os modelos de módulo
//   [ACID]    version field + SELECT FOR UPDATE nas reservas
//   [GDPR]    dados sensíveis separados, encriptados em repouso
//   [AUDIT]   core_audit_logs imutável, campo module filtra por módulo
//   [GHOST]   soft delete em todos os recursos críticos
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// ENUMS — CORE
// =============================================================================

enum UserRole {
  ADMIN
  OWNER
  CLIENT
}

// [TENANT] Roles de staff por módulo numa única enum.
// Prefixo do módulo torna imediato perceber a que contexto pertence.
enum StaffRole {
  // Hotelaria
  HT_RECEPTIONIST
  HT_HOUSEKEEPER
  HT_MANAGER
  // Restauração
  DI_WAITER
  DI_CHEF
  DI_MANAGER
  // Beauty & Wellness
  BW_THERAPIST
  BW_RECEPTIONIST
  BW_MANAGER
  // Genérico (acesso a todos os módulos do negócio)
  GENERAL_MANAGER
}

enum BusinessSource {
  MANUAL
  GOOGLE
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// Módulos do sistema — usado em core_business_staff e core_audit_logs
enum AppModule {
  HT  // Hospitality
  DI  // Dining
  BW  // Beauty & Wellness
  EV  // Events
  HE  // Health
  ED  // Education
  PS  // Professional Services
}

// =============================================================================
// ENUMS — HOTELARIA (HT)
// =============================================================================

enum HtBookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
  CANCELLED
}

enum HtRoomStatus {
  CLEAN
  DIRTY
  CLEANING
  MAINTENANCE
  INSPECTING
}

enum HtPaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MULTICAIXA
  OTHER
}

enum HtPaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum HtFolioItemType {
  ACCOMMODATION
  MINIBAR
  ROOM_SERVICE
  LAUNDRY
  SPA
  RESTAURANT
  PARKING
  EXTRA_BED
  EARLY_CHECKIN
  LATE_CHECKOUT
  DAMAGE
  DISCOUNT    // valor negativo
  TAX
  OTHER
}

enum HtHousekeepingPriority {
  NORMAL
  URGENT      // checkout com hóspede à espera
}

// =============================================================================
// ENUMS — AUDIT (CORE)
// =============================================================================

enum AuditAction {
  // Hotelaria
  HT_BOOKING_CREATED
  HT_BOOKING_CONFIRMED
  HT_BOOKING_CANCELLED
  HT_BOOKING_CHECKED_IN
  HT_BOOKING_CHECKED_OUT
  HT_BOOKING_NO_SHOW
  HT_BOOKING_MODIFIED
  HT_FOLIO_ITEM_ADDED
  HT_FOLIO_ITEM_REMOVED
  HT_PAYMENT_REGISTERED
  HT_PAYMENT_REFUNDED
  HT_ROOM_STATUS_CHANGED
  HT_ROOM_ASSIGNED
  HT_ROOM_REASSIGNED
  HT_GUEST_PROFILE_UPDATED
  HT_RATE_CHANGED
  // Dining (exemplo — expande quando o módulo for implementado)
  DI_ORDER_CREATED
  DI_ORDER_CANCELLED
  DI_TABLE_BOOKING_CREATED
  // Core
  CORE_STAFF_ADDED
  CORE_STAFF_REVOKED
  CORE_BUSINESS_CLAIMED
}

// =============================================================================
// ENUMS — INTERACÇÕES SOCIAIS
// =============================================================================

enum InteractionType {
  BOOKMARK  // utilizador guardou o negócio
  FOLLOW    // utilizador segue o negócio
  CHECKIN   // utilizador fez check-in físico
}

// =============================================================================
// MODELOS CORE (sem prefixo — infraestrutura partilhada)
// =============================================================================

model User {
  id            String               @id @default(uuid())
  email         String               @unique
  password      String
  role          UserRole
  name          String
  isSuspended   Boolean              @default(false)
  suspendedAt   DateTime?
  suspensionReason String?
  // Core relations
  businesses    Business[]
  refreshTokens RefreshToken[]
  notifications Notification[]
  deviceTokens  DeviceToken[]
  claimRequests ClaimRequest[]
  // Interacções sociais
  interactions  UserBusinessInteraction[]
  feedPosts     BusinessFeedPost[]
  loyaltyLedger LoyaltyLedger[]
  // Avaliações & Q&A
  reviews       Review[]
  questions     BusinessQuestion[]
  // PMS / módulos
  htBookings    HtRoomBooking[]
  staffRoles    CoreBusinessStaff[]
  auditActions  CoreAuditLog[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model Business {
  id             String                 @id @default(uuid())
  name           String
  category       String
  description    String
  metadata       Json?
  latitude       Float
  longitude      Float
  municipality   String?
  isActive       Boolean                @default(true)
  ownerId        String?
  owner          User?                  @relation(fields: [ownerId], references: [id])
  isClaimed      Boolean                @default(false)
  claimedAt      DateTime?
  source         BusinessSource         @default(MANUAL)
  googlePlaceId  String?                @unique
  // Interacções sociais
  interactions   UserBusinessInteraction[]
  feedPosts      BusinessFeedPost[]
  loyaltyLedger  LoyaltyLedger[]
  // Avaliações & Q&A
  reviews        Review[]
  questions      BusinessQuestion[]
  // Core relations
  operatingHours OperatingHour[]
  notifications  Notification[]
  claimRequests  ClaimRequest[]
  suggestions    DataUpdateSuggestion[]
  items          Item[]
  // Cross-módulo
  staffMembers   CoreBusinessStaff[]
  auditLogs      CoreAuditLog[]
  // HT — Hotelaria
  htConfig       HtPmsConfig?
  htRoomTypes    HtRoomType[]
  htRooms        HtRoom[]
  htBookings     HtRoomBooking[]
  htGuests       HtGuestProfile[]
  htFolioItems   HtFolioItem[]
  // DI — Dining (reservas de mesa já existentes)
  diBookings     DiTableBooking[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

// Staff partilhado entre módulos do mesmo negócio.
// Um funcionário pode ter roles em HT e DI simultaneamente (duas linhas).
// [TENANT] businessId + userId + module são únicos em conjunto.
model CoreBusinessStaff {
  id         String    @id @default(uuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  // null = acesso a todos os módulos (GENERAL_MANAGER)
  module     AppModule?
  role       StaffRole
  // [AUDIT] quem adicionou / revogou — soft revoke
  addedById  String?
  revokedAt  DateTime?
  revokedById String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Um utilizador só pode ter um role por módulo por negócio
  @@unique([businessId, userId, module])
  @@map("core_business_staff")
}

// Log central imutável — cobre todos os módulos.
// [AUDIT] Sem updatedAt. Sem DELETE. Sem UPDATE.
// [GDPR]  previousData / newData nunca contêm dados pessoais — só IDs e status.
model CoreAuditLog {
  id           String      @id @default(uuid())
  // [TENANT]
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id])
  // Qual módulo gerou este evento
  module       AppModule
  action       AuditAction
  // Quem fez — null se ação automática do sistema
  actorId      String?
  actor        User?       @relation(fields: [actorId], references: [id])
  // Recurso afetado
  resourceType String      // "HtRoomBooking" | "HtRoom" | "DiTableBooking"…
  resourceId   String
  // Snapshots de estado — [GDPR] nunca incluir campos pessoais aqui
  previousData Json?
  newData      Json?
  // Metadados
  ipAddress    String?
  note         String?
  createdAt    DateTime    @default(now())
  // Sem updatedAt — imutável por design

  @@map("core_audit_logs")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenId   String    @unique
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Notification {
  id         String   @id @default(uuid())
  title      String
  message    String
  isRead     Boolean  @default(false)
  data       Json?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OperatingHour {
  id         String   @id @default(uuid())
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, dayOfWeek])
}

model Item {
  id          String   @id @default(uuid())
  name        String
  price       Float
  capacity    Int
  description String
  available   Boolean  @default(true)
  totalRooms  Int      @default(1)
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClaimRequest {
  id         String      @id @default(uuid())
  businessId String
  userId     String
  status     ClaimStatus @default(PENDING)
  evidence   String
  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?
  business   Business    @relation(fields: [businessId], references: [id])
  user       User        @relation(fields: [userId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([businessId, userId])
  @@map("claim_requests")
}

model DataUpdateSuggestion {
  id            String           @id @default(uuid())
  businessId    String
  business      Business         @relation(fields: [businessId], references: [id])
  source        BusinessSource
  status        SuggestionStatus @default(PENDING)
  suggestedData Json
  currentData   Json
  reviewedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("data_update_suggestions")
}

// =============================================================================
// INTERACÇÕES SOCIAIS — Bookmark, Follow, Check-in
// Many-to-Many entre User e Business com tipo e deduplicação nativa
// =============================================================================

model UserBusinessInteraction {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       InteractionType
  // date só preenchida para CHECKIN (YYYY-MM-DD) — limita 1 check-in por dia
  date       String?
  createdAt  DateTime        @default(now())

  // Previne duplicados:
  // BOOKMARK/FOLLOW: unique por userId + businessId + type
  // CHECKIN:         unique por userId + businessId + type + date
  @@unique([userId, businessId, type, date])
  @@index([userId, type])       // "todos os bookmarks do user X"
  @@index([businessId, type])   // "todos os seguidores do negócio Y"
}

// Feed social do negócio para descoberta e prova social.
model BusinessFeedPost {
  id         String    @id @default(uuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  content    String
  mediaUrl   String?
  isPinned   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([businessId, createdAt])
  @@map("business_feed_posts")
}

// Ledger de pontos de fidelidade para auditoria e saldo acumulado por negócio.
model LoyaltyLedger {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pointsDelta Int
  reason     String
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([userId, businessId, createdAt])
  @@index([businessId, createdAt])
  @@map("loyalty_ledger")
}

// =============================================================================
// AVALIAÇÕES — Reviews + Helpful + Resposta do proprietário
// =============================================================================

model Review {
  id             String          @id @default(uuid())
  businessId     String
  business       Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating         Int             // 1-5
  comment        String
  helpfulCount   Int             @default(0)
  ownerReply     String?
  ownerReplyDate DateTime?
  helpful        ReviewHelpful[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([userId, businessId])
  @@index([businessId, createdAt])
  @@map("reviews")
}

// Um utilizador só pode marcar "útil" uma vez por avaliação
model ReviewHelpful {
  id       String @id @default(uuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId   String

  @@unique([reviewId, userId])
  @@map("review_helpful")
}

// =============================================================================
// Q&A — Perguntas & Respostas
// =============================================================================

model BusinessQuestion {
  id           String            @id @default(uuid())
  businessId   String
  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     String
  answer       String?
  answeredAt   DateTime?
  helpfulCount Int               @default(0)
  helpful      QuestionHelpful[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([businessId, createdAt])
  @@map("business_questions")
}

// Um utilizador só pode votar uma vez por pergunta
model QuestionHelpful {
  id         String           @id @default(uuid())
  questionId String
  question   BusinessQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String

  @@unique([questionId, userId])
  @@map("question_helpful")
}

// Registo de tokens para push (Expo/FCM), compatível com múltiplos devices por utilizador.
model DeviceToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String
  provider   String    @default("expo")
  platform   String?
  appVersion String?
  lastSeenAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, token])
  @@index([provider, updatedAt])
  @@map("device_tokens")
}

// =============================================================================
// MÓDULO HT — HOTELARIA / PMS
// Todas as tabelas com prefixo ht_
// =============================================================================

// Configuração operacional do hotel.
// Um registo por Business — campos tipados em vez de metadata JSON livre.
model HtPmsConfig {
  id                  String   @id @default(uuid())
  // [TENANT]
  businessId          String   @unique
  business            Business @relation(fields: [businessId], references: [id])
  // Horários
  defaultCheckInTime  String   @default("14:00")
  defaultCheckOutTime String   @default("12:00")
  lateCheckoutFee     Float    @default(0)
  earlyCheckinFee     Float    @default(0)
  // Políticas
  minNights           Int      @default(1)
  cancelPolicy        String   @default("flexible")
  includesBreakfast   Boolean  @default(false)
  petsAllowed         Boolean  @default(false)
  instantConfirm      Boolean  @default(false)
  noShowPenalty       Float    @default(0)   // penalização em Kz (0 = sem penalização)
  // iCal — canal manager
  icalExportToken     String?  // token secreto para URL de exportação
  icalImportUrl       String?  // URL do Booking.com / Airbnb
  // Faturação Angola
  vatNumber           String?  // NIF do estabelecimento (AGT)
  invoicePrefix       String?  // ex: "ACH-HTL"
  invoiceSequence     Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("ht_pms_config")
}

// Tipo de quarto (Standard, Suite, Bangalô…)
model HtRoomType {
  id                String          @id @default(uuid())
  // [TENANT]
  businessId        String
  business          Business        @relation(fields: [businessId], references: [id])
  name              String
  description       String          @default("")
  pricePerNight     Float
  maxGuests         Int             @default(2)
  totalRooms        Int             @default(1)
  available         Boolean         @default(true)
  amenities         String[]        @default([])
  minNights         Int             @default(1)
  taxRate           Float           @default(0)
  weekendMultiplier Float           @default(1.0)
  seasonalRates     Json?           // [{ label, from, to, pricePerNight }]
  photos            String[]        @default([])
  rooms             HtRoom[]
  bookings          HtRoomBooking[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("ht_room_types")
}

// Quarto físico individual numerado.
// Separado do HtRoomType para housekeeping e atribuição no check-in.
model HtRoom {
  id         String               @id @default(uuid())
  // [TENANT]
  businessId String
  business   Business             @relation(fields: [businessId], references: [id])
  roomTypeId String
  roomType   HtRoomType           @relation(fields: [roomTypeId], references: [id])
  number     String               // "101", "202", "Bangalô 3"
  floor      Int?
  status     HtRoomStatus         @default(CLEAN)
  notes      String?
  // [ACID] optimistic locking para housekeeping concorrente
  version    Int                  @default(0)
  bookings   HtRoomBooking[]
  tasks      HtHousekeepingTask[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([businessId, number])
  @@index([businessId, status])          // dashboard + auto-assign CLEAN
  @@index([roomTypeId, status])           // overlap check por tipo
  @@map("ht_rooms")
}

// [GDPR] Perfil do hóspede separado da reserva.
// Dados sensíveis nunca expostos na vista pública nem no audit log.
// Acesso restrito a OWNER + HT_RECEPTIONIST + HT_MANAGER.
model HtGuestProfile {
  id             String          @id @default(uuid())
  // [TENANT]
  businessId     String
  business       Business        @relation(fields: [businessId], references: [id])
  // Dados de contacto
  fullName       String
  phone          String?
  email          String?
  // [GDPR] Dados de identificação — encriptados em repouso (AES-256)
  documentType   String?         // "BI" | "Passaporte" | "DIRE"
  documentNumber String?         // encriptado
  companyName    String?
  nif            String?
  nationality    String?
  dateOfBirth    DateTime?       // encriptado
  address        String?
  // Preferências operacionais (visíveis ao staff)
  preferences    String?         // "piso alto, cama king"
  notes          String?         // "VIP — cliente desde 2022"
  isVip          Boolean         @default(false)
  // [AUDIT] alteração de blacklist sempre registada no CoreAuditLog
  isBlacklisted  Boolean         @default(false)
  bookings       HtRoomBooking[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([businessId, documentNumber])
  @@index([businessId, nif])
  @@map("ht_guest_profiles")
}

// Reserva de quarto.
// [TENANT] businessId validado no service antes de qualquer query.
// [ACID]   criação usa transação com SELECT FOR UPDATE no HtRoomType.
// Preço SEMPRE calculado no backend — nunca aceite do frontend.
model HtRoomBooking {
  id              String           @id @default(uuid())
  // [TENANT]
  businessId      String
  business        Business         @relation(fields: [businessId], references: [id])
  roomTypeId      String?
  roomType        HtRoomType?      @relation(fields: [roomTypeId], references: [id])
  // Quarto físico atribuído no check-in (null até essa altura)
  roomId          String?
  room            HtRoom?          @relation(fields: [roomId], references: [id])
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  // [GDPR] dados sensíveis em HtGuestProfile — não inline
  guestProfileId  String?
  guestProfile    HtGuestProfile?  @relation(fields: [guestProfileId], references: [id])
  // Campos mantidos para compatibilidade com frontend atual
  guestName       String?
  guestPhone      String?
  startDate       DateTime
  endDate         DateTime
  status          HtBookingStatus  @default(PENDING)
  adults          Int              @default(1)
  children        Int              @default(0)
  rooms           Int              @default(1)
  // Financeiro — calculado no backend
  totalPrice      Float?
  depositPaid     Float?           @default(0)
  paymentStatus   HtPaymentStatus  @default(PENDING)
  paymentMethod   HtPaymentMethod?
  notes           String?
  voucherCode     String?
  // Timestamps operacionais — [AUDIT] registados também no CoreAuditLog
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  originalEndDate DateTime?         // data prevista de saída antes de checkout antecipado
  noShowAt        DateTime?
  // [ACID] optimistic locking para alterações concorrentes
  version         Int              @default(0)
  folio           HtFolioItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Índices para queries de disponibilidade e dashboard
  @@index([businessId, status])
  @@index([roomTypeId, status, startDate, endDate])  // overlap check
  @@index([roomId, status])                           // auto-assign + conflito extend
  @@index([businessId, startDate])                    // arrivals
  @@index([businessId, endDate])                      // departures
  @@index([userId, createdAt])                        // histórico do cliente
  @@map("ht_room_bookings")
}

// Conta corrente do hóspede durante a estadia.
// [AUDIT] Soft delete — nunca apagar fisicamente.
// [TENANT] businessId obrigatório — impede acesso cruzado entre hotéis.
model HtFolioItem {
  id           String          @id @default(uuid())
  // [TENANT]
  businessId   String
  business     Business        @relation(fields: [businessId], references: [id])
  bookingId    String
  booking      HtRoomBooking   @relation(fields: [bookingId], references: [id])
  type         HtFolioItemType
  description  String
  amount       Float           // negativo = desconto
  quantity     Int             @default(1)
  unitPrice    Float
  // Quem lançou
  addedById    String?
  addedAt      DateTime        @default(now())
  // [AUDIT] soft delete
  removedAt    DateTime?
  removedById  String?
  removeReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([bookingId, removedAt])   // getFolio query
  @@map("ht_folio_items")
}

// Tarefas de limpeza — geradas automaticamente após CHECKED_OUT / NO_SHOW.
model HtHousekeepingTask {
  id            String                 @id @default(uuid())
  roomId        String
  room          HtRoom                 @relation(fields: [roomId], references: [id])
  assignedToId  String?
  priority      HtHousekeepingPriority @default(NORMAL)
  startedAt     DateTime?
  completedAt   DateTime?
  notes         String?
  inspectedById String?
  inspectedAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@map("ht_housekeeping_tasks")
}

// =============================================================================
// MÓDULO DI — DINING (RESTAURAÇÃO)
// Reservas de mesa existentes renomeadas com prefixo di_
// =============================================================================

model DiTableBooking {
  id         String          @id @default(uuid())
  startDate  DateTime
  endDate    DateTime
  status     HtBookingStatus // reutiliza o enum — ou criar DiBookingStatus
  userId     String
  businessId String
  business   Business        @relation(fields: [businessId], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@map("di_table_bookings")
}

