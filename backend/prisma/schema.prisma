// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  OWNER
  CLIENT
}

enum BusinessCategory {
  HOSPITALITY
  DINING
  BEAUTY
  PROFESSIONAL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// ─── NOVO ────────────────────────────────────────────────────────────────────
enum BusinessSource {
  GOOGLE   // importado via Google Places API
  MANUAL   // criado manualmente pelo dono
}

enum ClaimStatus {
  PENDING   // pedido submetido, aguarda revisão do admin
  APPROVED  // admin aprovou — dono passa a controlar
  REJECTED  // admin rejeitou
}
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  password      String
  role          UserRole
  name          String
  bookings      Booking[]
  roomBookings  RoomBooking[]
  businesses    Business[]      // negócios onde é dono
  claimRequests ClaimRequest[]  // pedidos de claim submetidos
  refreshTokens RefreshToken[]
  notifications Notification[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Business {
  id             String           @id @default(uuid())
  name           String
  category       BusinessCategory
  description    String
  metadata       Json?
  latitude       Float
  longitude      Float

  // ─── Multi-tenant ──────────────────────────────────────────────────────────
  ownerId        String?          // nullable — negócios não reclamados não têm dono
  owner          User?            @relation(fields: [ownerId], references: [id])
  isClaimed      Boolean          @default(false)
  claimedAt      DateTime?
  source         BusinessSource   @default(MANUAL)
  googlePlaceId  String?          @unique  // ID único do Google Places
  claimRequests  ClaimRequest[]
  // ──────────────────────────────────────────────────────────────────────────

  bookings       Booking[]
  roomBookings   RoomBooking[]
  items          Item[]
  operatingHours OperatingHour[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

// ─── NOVO ────────────────────────────────────────────────────────────────────
// Registo de pedidos de claim de negócio por parte de donos
model ClaimRequest {
  id           String      @id @default(uuid())
  businessId   String
  business     Business    @relation(fields: [businessId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  status       ClaimStatus @default(PENDING)
  evidence     String?     // texto livre: justificação, URL de documento, etc.
  adminNote    String?     // nota interna do admin ao aprovar/rejeitar
  reviewedAt   DateTime?
  reviewedBy   String?     // userId do admin que reviu
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([businessId, userId]) // um user só pode ter um pedido activo por negócio
  @@map("claim_requests")
}
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id         String        @id @default(uuid())
  startDate  DateTime
  endDate    DateTime
  status     BookingStatus
  userId     String
  businessId String
  user       User          @relation(fields: [userId], references: [id])
  business   Business      @relation(fields: [businessId], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("table_bookings")
}

model RoomBooking {
  id         String        @id @default(uuid())
  startDate  DateTime
  endDate    DateTime
  status     BookingStatus
  userId     String
  businessId String
  user       User          @relation(fields: [userId], references: [id])
  business   Business      @relation(fields: [businessId], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("room_bookings")
}

model RefreshToken {
  id         String   @id @default(uuid())
  tokenId    String   @unique
  tokenHash  String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Item {
  id          String   @id @default(uuid())
  name        String
  price       Float
  capacity    Int
  description String
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OperatingHour {
  id         String   @id @default(uuid())
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, dayOfWeek])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  data      Json?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
